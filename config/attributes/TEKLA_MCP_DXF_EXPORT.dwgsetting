      &lt;Filter ObjectType="DrawingTable" FilterName="" GroupingStyle="All" /&gt;
    &lt;/MappingRule&gt;
    &lt;MappingRule&gt;
      &lt;Setting IncludeInExport="true" Color="AsTSObject" LineStyle="AsTSObject" LineWeight="ByDwgLayer" PaperSpace="true" LayerName="TEKLA_MCP_DRAWING_FRAME" /&gt;
      &lt;Filter ObjectType="DrawingFrame" FilterName="" GroupingStyle="All" /&gt;
    &lt;/MappingRule&gt;
    &lt;MappingRule&gt;
      &lt;Setting IncludeInExport="true" Color="AsTSObject" LineStyle="AsTSObject" LineWeight="ByDwgLayer" PaperSpace="true" LayerName="TEKLA_MCP_VIEW_LABEL" /&gt;
