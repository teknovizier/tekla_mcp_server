    &lt;MappingRule&gt;
      &lt;Setting IncludeInExport="true" Color="AsTSObject" LineStyle="AsTSObject" LineWeight="ByDwgLayer" PaperSpace="false" LayerName="TEKLA_MCP_GRIDS" /&gt;
      &lt;Filter ObjectType="GridLine" FilterName="" GroupingStyle="All" /&gt;
    &lt;/MappingRule&gt;
    &lt;MappingRule&gt;
      &lt;Setting IncludeInExport="true" Color="AsTSObject" LineStyle="AsTSObject" LineWeight="ByDwgLayer" PaperSpace="false" LayerName="TEKLA_MCP_REINFORCEMENT" /&gt;
      &lt;Filter ObjectType="ReinforcementBase" FilterName="" GroupingStyle="All" /&gt;
    &lt;/MappingRule&gt;
    &lt;MappingRule&gt;
      &lt;Setting IncludeInExport="true" Color="AsTSObject" LineStyle="AsTSObject" LineWeight="ByDwgLayer" PaperSpace="false" LayerName="TEKLA_MCP_SURFACE_TREATMENT" /&gt;
      &lt;Filter ObjectType="Surfacing" FilterName="" GroupingStyle="All" /&gt;
    &lt;/MappingRule&gt;
    &lt;MappingRule&gt;
      &lt;Setting IncludeInExport="true" Color="AsTSObject" LineStyle="AsTSObject" LineWeight="ByDwgLayer" PaperSpace="true" LayerName="TEKLA_MCP_DIMENSIONS" /&gt;
      &lt;Filter ObjectType="DimensionBase" FilterName="" GroupingStyle="All" /&gt;
    &lt;/MappingRule&gt;
    &lt;MappingRule&gt;
      &lt;Setting IncludeInExport="true" Color="AsTSObject" LineStyle="AsTSObject" LineWeight="ByDwgLayer" PaperSpace="true" LayerName="TEKLA_MCP_MARKS" /&gt;
      &lt;Filter ObjectType="MarkBase" FilterName="" GroupingStyle="All" /&gt;
    &lt;/MappingRule&gt;
    &lt;MappingRule&gt;
      &lt;Setting IncludeInExport="true" Color="AsTSObject" LineStyle="AsTSObject" LineWeight="ByDwgLayer" PaperSpace="true" LayerName="TEKLA_MCP_DETAIL_MARKS" /&gt;
