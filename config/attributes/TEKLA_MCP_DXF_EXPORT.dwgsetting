      &lt;Filter ObjectType="Image" FilterName="" GroupingStyle="All" /&gt;
    &lt;/MappingRule&gt;
    &lt;MappingRule&gt;
      &lt;Setting IncludeInExport="true" Color="AsTSObject" LineStyle="AsTSObject" LineWeight="ByDwgLayer" PaperSpace="true" LayerName="TEKLA_MCP_DWG_FILES" /&gt;
