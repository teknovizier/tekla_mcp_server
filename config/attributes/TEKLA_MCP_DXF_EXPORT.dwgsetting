      &lt;Filter ObjectType="Symbol" FilterName="" GroupingStyle="All" /&gt;
    &lt;/MappingRule&gt;
    &lt;MappingRule&gt;
      &lt;Setting IncludeInExport="true" Color="AsTSObject" LineStyle="AsTSObject" LineWeight="ByDwgLayer" PaperSpace="true" LayerName="TEKLA_MCP_TEXT" /&gt;
      &lt;Filter ObjectType="Text" FilterName="" GroupingStyle="All" /&gt;
    &lt;/MappingRule&gt;
    &lt;MappingRule&gt;
      &lt;Setting IncludeInExport="true" Color="AsTSObject" LineStyle="AsTSObject" LineWeight="ByDwgLayer" PaperSpace="true" LayerName="TEKLA_MCP_TEXT_FILES" /&gt;
      &lt;Filter ObjectType="TextFile" FilterName="" GroupingStyle="All" /&gt;
    &lt;/MappingRule&gt;
    &lt;MappingRule&gt;
      &lt;Setting IncludeInExport="true" Color="AsTSObject" LineStyle="AsTSObject" LineWeight="ByDwgLayer" PaperSpace="false" LayerName="TEKLA_MCP_ALL" /&gt;
      &lt;Filter ObjectType="DrawingObject" FilterName="" GroupingStyle="All" /&gt;
    &lt;/MappingRule&gt;
  &lt;/MappingRules&gt;
&lt;/ObjectMappingRules&gt;</LayerRules>
</DwgExportOptions>