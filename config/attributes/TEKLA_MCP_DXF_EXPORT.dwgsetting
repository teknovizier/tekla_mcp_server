<?xml version="1.0" encoding="utf-8"?>
<DwgExportOptions Version="1.1">
  <FileAttributes FileExtension=".dxf" FilePrefix="TEKLA_MCP_" FileSuffix="" FileVersion="Dwg.UI.DwgFileVersion.vAC24" />
  <Preferences OpenFolder="false" OutputDirectory=".\PlotFiles" UpdateExisting="false" EmbedImages="true" WithoutBlocks="false" IncludeViewsOutsideSheet="true" SnapshotToModelSpace="true" SnapshotScale="1.0" CoordinatesToUse="Model" />
  <LayerRules>&lt;?xml version="1.0" encoding="utf-16"?&gt;
&lt;ObjectMappingRules xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"&gt;
  &lt;LayerTemplate /&gt;
  &lt;Version&gt;1.0&lt;/Version&gt;
  &lt;MappingRules&gt;
    &lt;MappingRule&gt;
      &lt;Setting IncludeInExport="true" Color="AsTSObject" LineStyle="AsTSObject" LineWeight="ByDwgLayer" PaperSpace="false" LayerName="TEKLA_MCP_PARTS" /&gt;
      &lt;Filter ObjectType="Part" FilterName="" GroupingStyle="Lines" /&gt;
    &lt;/MappingRule&gt;
    &lt;MappingRule&gt;
      &lt;Setting IncludeInExport="true" Color="AsTSObject" LineStyle="AsTSObject" LineWeight="ByDwgLayer" PaperSpace="false" LayerName="TEKLA_MCP_HATCHES" /&gt;
      &lt;Filter ObjectType="Part" FilterName="" GroupingStyle="Fills" /&gt;
    &lt;/MappingRule&gt;
    &lt;MappingRule&gt;
      &lt;Setting IncludeInExport="true" Color="AsTSObject" LineStyle="AsTSObject" LineWeight="ByDwgLayer" PaperSpace="false" LayerName="TEKLA_MCP_HIDDEN_LINES" /&gt;
      &lt;Filter ObjectType="Part" FilterName="" GroupingStyle="HiddenLines" /&gt;
    &lt;/MappingRule&gt;
    &lt;MappingRule&gt;
      &lt;Setting IncludeInExport="true" Color="AsTSObject" LineStyle="AsTSObject" LineWeight="ByDwgLayer" PaperSpace="false" LayerName="TEKLA_MCP_REFERENCE_LINES" /&gt;
      &lt;Filter ObjectType="Part" FilterName="" GroupingStyle="ReferenceLines" /&gt;
    &lt;/MappingRule&gt;
    &lt;MappingRule&gt;
      &lt;Setting IncludeInExport="true" Color="AsTSObject" LineStyle="AsTSObject" LineWeight="ByDwgLayer" PaperSpace="false" LayerName="TEKLA_MCP_CENTER_LINES" /&gt;
      &lt;Filter ObjectType="Part" FilterName="" GroupingStyle="CenterLines" /&gt;
    &lt;/MappingRule&gt;
    &lt;MappingRule&gt;
      &lt;Setting IncludeInExport="true" Color="AsTSObject" LineStyle="AsTSObject" LineWeight="ByDwgLayer" PaperSpace="false" LayerName="TEKLA_MCP_SECTION_EDGES" /&gt;
      &lt;Filter ObjectType="Part" FilterName="" GroupingStyle="SectionEdgeLines" /&gt;
    &lt;/MappingRule&gt;
    &lt;MappingRule&gt;
      &lt;Setting IncludeInExport="true" Color="AsTSObject" LineStyle="AsTSObject" LineWeight="ByDwgLayer" PaperSpace="false" LayerName="TEKLA_MCP_SECTION_HATCHES" /&gt;
      &lt;Filter ObjectType="Part" FilterName="" GroupingStyle="SectionFills" /&gt;
    &lt;/MappingRule&gt;
    &lt;MappingRule&gt;
      &lt;Setting IncludeInExport="true" Color="AsTSObject" LineStyle="AsTSObject" LineWeight="ByDwgLayer" PaperSpace="false" LayerName="TEKLA_MCP_BOLTS" /&gt;
      &lt;Filter ObjectType="Bolt" FilterName="" GroupingStyle="All" /&gt;
